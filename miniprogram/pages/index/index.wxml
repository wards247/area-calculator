<view class="container">
  <!-- 工具栏：用 view 代替 button，避免原生 disabled 导致不可点击 -->
  <view class="toolbar">
    <view class="btn btn-trace {{tracing ? 'active' : ''}}" bindtap="onTraceToggle">{{tracing ? '✏️描边中' : '✏️描边'}}</view>
    <view class="btn btn-undo {{canUndo ? '' : 'btn-disabled'}}" bindtap="onUndo">↩撤销</view>
    <view class="btn btn-done {{showDoneBtn ? '' : 'btn-disabled'}}" bindtap="onDone">✅完成</view>
    <view class="btn btn-clear {{showClearBtn ? '' : 'btn-disabled'}}" bindtap="onClear">🗑️清空</view>
    <view class="btn btn-grid {{showGridBtn ? '' : 'btn-disabled'}}" bindtap="onGridToggle">{{gridOn ? '🔲隐藏' : '🔲网格'}}</view>
  </view>

  <!-- 信息栏 -->
  <view class="info-bar">
    <view class="info-item">
      <text class="lbl">总面积（亩）</text>
      <input class="val total-input" type="digit" value="{{totalArea}}" bindinput="onTotalAreaInput" bindblur="onTotalAreaBlur" />
    </view>
    <view class="info-item info-narrow">
      <text class="lbl">描点</text>
      <text class="val">{{ptCount}}</text>
    </view>
    <view class="info-item info-narrow">
      <text class="lbl">总格数</text>
      <text class="val">{{totalCellCount}}</text>
    </view>
    <view class="info-item info-narrow">
      <text class="lbl">选中格</text>
      <text class="val">{{cellCount}}</text>
    </view>
    <view class="info-item info-area">
      <text class="lbl">选中面积</text>
      <view class="area-row">
        <text class="val">{{areaVal}}<text class="unit">亩</text></text>
        <text class="sub">{{areaSub}}<text class="sub-unit">㎡</text></text>
      </view>
    </view>
  </view>

  <!-- 主内容区 -->
  <view class="main-content">
    <view class="map-area" id="map-area">
      <!-- 背景图 -->
      <image wx:if="{{imgSrc}}" id="bg-img" src="{{imgSrc}}" mode="aspectFit" bindload="onImgLoad" />
      <!-- 描边 canvas -->
      <canvas type="2d" id="trace-canvas" class="trace-canvas"
        bindtouchstart="onTraceTouchStart"
        bindtouchmove="onTraceTouchMove"
        bindtouchend="onTraceTouchEnd" />
      <!-- 网格 canvas：动态切换 show 类控制显隐 -->
      <canvas type="2d" id="grid-canvas" class="grid-canvas {{gridOn ? 'show' : ''}}"
        bindtouchstart="onGridTouchStart"
        bindtouchmove="onGridTouchMove"
        bindtouchend="onGridTouchEnd" />
      <!-- 描边提示 -->
      <view class="trace-tip" wx:if="{{showTraceTip}}">{{traceTipText}}</view>
    </view>

    <!-- 比例面板 -->
    <view class="ratio-panel" wx:if="{{showRatioPanel}}">
      <view class="panel-title">📐 比例填充</view>
      <view class="ratio-presets">
        <view class="ratio-btn {{ratioA===60&&ratioB===40?'active':''}}" bindtap="onRatioPreset" data-a="60" data-b="40">60%</view>
        <view class="ratio-btn {{ratioA===65&&ratioB===35?'active':''}}" bindtap="onRatioPreset" data-a="65" data-b="35">65%</view>
        <view class="ratio-btn {{ratioA===70&&ratioB===30?'active':''}}" bindtap="onRatioPreset" data-a="70" data-b="30">70%</view>
      </view>
      <view class="ratio-custom">
        <input type="number" class="ratio-input" value="{{ratioA}}" bindinput="onRatioAInput" />
        <text class="pct-suffix">%</text>
        <view class="ratio-apply-btn" bindtap="onRatioCustom">应用</view>
      </view>
      <!-- A区B区改为竖排避免溢出 -->
      <view class="ratio-live">
        <text class="rl-label">当前占比</text>
        <text class="rl-pct">{{ratioPct}}</text>
        <view class="rl-detail">A区: {{ratioACells}}格 ({{ratioAArea}})</view>
        <view class="rl-detail">B区: {{ratioBCells}}格 ({{ratioBArea}})</view>
      </view>
      <view class="ratio-legend">
        <view class="leg-a">A区</view>
        <view class="leg-b">B区</view>
      </view>
    </view>
  </view>

  <!-- 提示区 -->
  <view class="hint">
    <text>{{hintText}}</text>
  </view>

  <!-- 上传入口（初始状态：上传按钮 + 使用说明） -->
  <view class="upload-overlay" wx:if="{{!imgSrc}}" catchtouchmove="noop">
    <view class="upload-card">
      <view class="upload-btn-area" bindtap="onChooseImage">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击上传地块规划图</text>
      </view>
      <view class="tutorial">
        <text class="tutorial-title">使用说明</text>
        <view class="tutorial-steps">
          <view class="step">
            <view class="step-num">1</view>
            <view class="step-text">
              <text class="step-title">上传底图</text>
              <text class="step-desc">拍照或选择地块规划图</text>
            </view>
          </view>
          <view class="step">
            <view class="step-num">2</view>
            <view class="step-text">
              <text class="step-title">描出地块</text>
              <text class="step-desc">沿边界依次点击描点，双击闭合</text>
            </view>
          </view>
          <view class="step">
            <view class="step-num">3</view>
            <view class="step-text">
              <text class="step-title">网格计算</text>
              <text class="step-desc">滑动选格或按比例自动填充</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
